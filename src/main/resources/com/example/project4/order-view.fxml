<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="900.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project4.gui.OrderController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" style="-fx-font-size: 18; -fx-font-weight: bold;" text="RU Pizzeria Order" />

    <HBox alignment="CENTER" spacing="15.0">
        <ComboBox fx:id="pizzaStyleComboBox" prefHeight="25.0" prefWidth="150.0" promptText="Pizza Style" />
        <ComboBox fx:id="pizzaSizeComboBox" prefHeight="25.0" prefWidth="150.0" promptText="Pizza Size" />
        <ComboBox fx:id="pizzaTypeComboBox" prefHeight="25.0" prefWidth="150.0" promptText="Pizza Type" />
    </HBox>

    <HBox alignment="CENTER" spacing="20.0">
        <VBox alignment="CENTER">
            <Label text="Available Toppings" />
            <ListView fx:id="availableToppingsListView" disable="true" prefHeight="150.0" prefWidth="150.0" />
            <Button fx:id="addToppingButton" disable="true" onAction="#onAddToppingClick" text="Add" />
        </VBox>
        <VBox alignment="CENTER">
            <Label text="Selected Toppings" />
            <ListView fx:id="selectedToppingsListView" prefHeight="150.0" prefWidth="150.0" />
            <Button fx:id="removeToppingButton" disable="true" onAction="#onRemoveToppingClick" text="Remove" />
        </VBox>
    </HBox>

    <!-- Dynamic Pizza Image Display -->
    <ImageView fx:id="pizzaImageView" fitHeight="150.0" fitWidth="200.0" preserveRatio="true" />

    <!-- Subtotal Label for Dynamic Cost Updates -->
    <Label fx:id="PizzaTotalLabel" style="-fx-font-size: 14; -fx-font-weight: bold;" text="Pizza Total: $" />
    <Label fx:id="statusLabel" style="-fx-font-size: 14; -fx-font-weight: bold;"/>

    <!-- Buttons for Order Actions -->
    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="addToOrderButton" onAction="#onAddToOrderClick" text="Add to Order" />
        <Button fx:id="clearSelectionButton" onAction="#clearButtonClicked" text="Clear Selection" />
        <Button onAction="#onViewOrderDetailsButtonClicked" text="View Your Order Cart" />
    </HBox>
</VBox>
